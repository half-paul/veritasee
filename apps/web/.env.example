# Clerk — managed auth provider (see docs/adr/0001-managed-auth.md)
# Get these from https://dashboard.clerk.com → your application → API keys

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_dXB3YXJkLWphd2Zpc2gtNTEuY2xlcmsuYWNjb3VudHMuZGV2JA
CLERK_SECRET_KEY=sk_test_hgChLSRiJzaIgGaGHlmiO24gvYpjeKESWv3hqZPzC1

# Optional: route overrides. Defaults shown.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# REQUIRED: customise the Clerk session token to surface publicMetadata so
# resolveRole() can read the user's role. In the Clerk dashboard go to
# Sessions → Customize session token and add:
#   {
#     "metadata": "{{user.public_metadata}}"
#   }
# Without this, every signed-in user resolves to the default role (contributor).

# Postgres (Neon) — see docs/adr/0002-postgres-orm.md
# Pooled URL: used by the app at runtime (transaction-mode pgbouncer).
DATABASE_URL=
# Unpooled URL: used ONLY for migrations and admin commands; pgbouncer is
# incompatible with the migration protocol. Drop "-pooler" from the host.
DATABASE_URL_UNPOOLED=

# Upstash Redis (region-pinned: EU + US)
# Provision two Upstash databases — one in eu-west-1, one in us-east-1 — and set
# the URL/token of the *primary region* for local development. Multi-region
# routing (selecting the closest replica per request) is wired in a later issue
# (VS-022 / VS-067); for now the app uses a single Upstash endpoint.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Object storage (S3-compatible: Cloudflare R2 or AWS S3) — see PRD §14.1, §17
# Provision a bucket in your provider, then create an access-key pair scoped
# to that bucket. For Cloudflare R2, set S3_FORCE_PATH_STYLE=true and use the
# R2 S3 API endpoint (https://<account>.r2.cloudflarestorage.com) with region
# "auto". For AWS S3, leave S3_FORCE_PATH_STYLE unset and use the standard
# regional endpoint.
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
# Required for Cloudflare R2; leave unset for AWS S3.
S3_FORCE_PATH_STYLE=
