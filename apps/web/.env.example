# Clerk — managed auth provider (see docs/adr/0001-managed-auth.md)
# Get these from https://dashboard.clerk.com → your application → API keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional: route overrides. Defaults shown.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# REQUIRED: customise the Clerk session token to surface publicMetadata so
# resolveRole() can read the user's role. In the Clerk dashboard go to
# Sessions → Customize session token and add:
#   {
#     "metadata": "{{user.public_metadata}}"
#   }
# Without this, every signed-in user resolves to the default role (contributor).

# Postgres (Neon) — see docs/adr/0002-postgres-orm.md
# Pooled URL: used by the app at runtime (transaction-mode pgbouncer).
DATABASE_URL=
# Unpooled URL: used ONLY for migrations and admin commands; pgbouncer is
# incompatible with the migration protocol. Drop "-pooler" from the host.
DATABASE_URL_UNPOOLED=
