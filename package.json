{
  "name": "veritasee",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "node scripts/with-env.mjs pnpm --filter web dev",
    "build": "node scripts/with-env.mjs pnpm --filter web build",
    "start": "node scripts/with-env.mjs pnpm --filter web start",
    "lint": "node scripts/with-env.mjs pnpm -r lint",
    "typecheck": "node scripts/with-env.mjs pnpm -r typecheck",
    "format": "node scripts/with-env.mjs prettier --write .",
    "format:check": "node scripts/with-env.mjs prettier --check .",
    "db:generate": "node scripts/with-env.mjs pnpm --filter @veritasee/db db:generate",
    "db:migrate": "node scripts/with-env.mjs pnpm --filter @veritasee/db db:migrate"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11"
  }
}
